{
  "info": {
    "_postman_id": "bfs-auth-user-api-v1",
    "name": "BFS Backend — Auth & User API",
    "description": "Complete Auth + User module API. Set {{baseUrl}} to http://localhost:3000 in your environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "resetToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1 · Register (Send OTP)",
          "event": [],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sakib Jaber\",\n  \"email\": \"sakib@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "2 · Verify OTP (Activate Account)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken)  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sakib@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          },
          "response": []
        },
        {
          "name": "3 · Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken)  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sakib@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "4 · Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken)  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "5 · Get Me (auth/me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "6 · Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "7 · Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sakib@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend-otp"]
            }
          },
          "response": []
        },
        {
          "name": "8 · Forgot Password (Send Reset OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sakib@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            }
          },
          "response": []
        },
        {
          "name": "9 · Verify Reset OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.resetToken) pm.collectionVariables.set('resetToken', json.data.resetToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sakib@example.com\",\n  \"otp\": \"654321\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-reset-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-reset-otp"]
            }
          },
          "response": []
        },
        {
          "name": "10 · Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword@456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "1 · Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          },
          "response": []
        },
        {
          "name": "2 · Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sakib Jaber Updated\",\n  \"bio\": \"Boat enthusiast and developer.\",\n  \"phone\": \"+8801711223344\",\n  \"socialLinks\": {\n    \"facebook\": \"https://facebook.com/sakibjaber\",\n    \"instagram\": \"https://instagram.com/sakibjaber\",\n    \"twitter\": \"https://twitter.com/sakibjaber\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/update-profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "update-profile"]
            }
          },
          "response": []
        },
        {
          "name": "2b · Update Profile with Image (multipart)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Sakib Jaber", "type": "text" },
                { "key": "bio", "value": "Updated bio", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users/update-profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "update-profile"]
            }
          },
          "response": []
        },
        {
          "name": "3 · Update Avatar (dedicated upload)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "avatar", "type": "file", "src": "" }]
            },
            "url": {
              "raw": "{{baseUrl}}/users/update-avatar",
              "host": ["{{baseUrl}}"],
              "path": ["users", "update-avatar"]
            }
          },
          "response": []
        },
        {
          "name": "4 · Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"Password@123\",\n  \"newPassword\": \"NewPassword@456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["users", "change-password"]
            }
          },
          "response": []
        },
        {
          "name": "5 · Register FCM Token",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fcm-device-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/fcm-token",
              "host": ["{{baseUrl}}"],
              "path": ["users", "fcm-token"]
            }
          },
          "response": []
        },
        {
          "name": "6 · Remove FCM Token",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fcm-device-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/fcm-token",
              "host": ["{{baseUrl}}"],
              "path": ["users", "fcm-token"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users (Admin Only)",
      "item": [
        {
          "name": "1 · List All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10&role=USER&search=",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                {
                  "key": "role",
                  "value": "USER",
                  "description": "USER | ADMIN | SUPER_ADMIN"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by name or email"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "2 · Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "<userId>" }]
            }
          },
          "response": []
        },
        {
          "name": "3 · Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "<userId>" }]
            }
          },
          "response": []
        },
        {
          "name": "4 · Toggle User Status (Block / Unblock)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "none" },
            "url": {
              "raw": "{{baseUrl}}/users/:id/toggle-status",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "toggle-status"],
              "variable": [{ "key": "id", "value": "<userId>" }]
            }
          },
          "response": []
        },
        {
          "name": "5 · Change User Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/:id/role",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id", "role"],
              "variable": [{ "key": "id", "value": "<userId>" }]
            }
          },
          "response": []
        },
        {
          "name": "6 · Create Admin (Super-Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@example.com\",\n  \"password\": \"Admin@Secure1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/admin",
              "host": ["{{baseUrl}}"],
              "path": ["users", "admin"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
